DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/berhan_pipeline

# Hatchet worker (Phase 6)
HATCHET_CLIENT_TOKEN=
HATCHET_CLIENT_HOSTPORT=localhost:7077

LOG_LEVEL=INFO
